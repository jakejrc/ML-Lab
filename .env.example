# ML-Lab 配置文件
# 复制此文件为 .env 并填入实际值，重启 ML-Lab 后生效

# ═══════════════════════════════════════
# AI 助教 - 大模型配置（OpenAI 兼容格式）
# ═══════════════════════════════════════

# API 地址（必填，去掉末尾斜杠）
# 预设示例：
#   通义千问:   https://dashscope.aliyuncs.com/compatible-mode/v1
#   OpenRouter: https://openrouter.ai/api/v1
#   硅基流动:   https://api.siliconflow.cn/v1
#   Ollama本地: http://localhost:11434/v1
#   智谱GLM:    https://open.bigmodel.cn/api/paas/v4
#   DeepSeek:   https://api.deepseek.com/v1
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型名称（必填）
# 预设示例：
#   qwen-turbo / qwen-plus / qwen-max
#   meta-llama/llama-3-8b-instruct:free
#   Qwen/Qwen2.5-7B-Instruct
#   qwen2.5:7b / glm-4-flash / deepseek-chat
LLM_MODEL=qwen-turbo

# API Key（Ollama 本地部署可留空）
LLM_API_KEY=

# ═══════════════════════════════════════
# Float Chat - 右下角浮动 AI 对话（OpenAI 兼容格式）
# 默认使用智谱 GLM-4-Flash，可替换为其他兼容 API
# ═══════════════════════════════════════

# Float Chat API 地址
FLOAT_CHAT_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions

# Float Chat 模型名称
FLOAT_CHAT_MODEL=glm-4-flash

# Float Chat API Key（必填，未配置则 Float Chat 不工作）
FLOAT_CHAT_API_KEY=
